generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  // Runtime queries connect as `portfolioos_app` (NOSUPERUSER, NOBYPASSRLS)
  // so RLS policies in migration 20260421140000_phase_4_5_rls are enforced.
  url       = env("DATABASE_URL")
  // Prisma CLI (`migrate dev`, `db push`, shadow DB) needs CREATE TABLE /
  // CREATE ROLE privileges — stay on `postgres` for that.
  directUrl = env("DIRECT_URL")
}

// ─── USERS & AUTH ───────────────────────────────────────────────

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  passwordHash          String
  name                  String
  phone                 String?
  pan                   String?
  dob                   DateTime?
  // Encrypted JSON array of passwords the user has supplied to unlock
  // PDF/XLSX uploads. Tried automatically on every locked file.
  // See lib/userDocPasswords.ts and lib/decryptIfNeeded.ts.
  savedFilePasswordsEnc String?
  role                  UserRole  @default(INVESTOR)
  plan                  PlanTier  @default(FREE)
  planExpiresAt         DateTime?
  isActive              Boolean   @default(true)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  portfolios          Portfolio[]
  portfolioGroups     PortfolioGroup[]
  clients             Client[]
  alerts              Alert[]
  importJobs          ImportJob[]
  accounts            Account[]
  vouchers            Voucher[]
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  brokerAccounts      BrokerAccount[]
  mailboxAccounts     MailboxAccount[]

  // Phase 4.5 hardening — ingestion + real-asset modules (§4.1–§4.9)
  canonicalEvents   CanonicalEvent[]
  monitoredSenders  MonitoredSender[]
  learnedTemplates  LearnedTemplate[]
  ingestionFailures IngestionFailure[]
  vehicles          Vehicle[]
  rentalProperties  RentalProperty[]
  insurancePolicies InsurancePolicy[]
  auditLogs         AuditLog[]

  // Phase 5-A — per-call LLM spend ledger (§8, §16 gate G5). Every
  // Anthropic API call writes a row here so the monthly budget check
  // can aggregate exactly what this user has spent.
  llmSpend LlmSpend[]

  sipPlans SipPlan[]

  // Phase 5-MFCentral — OTP-driven CAS sync (mProfit-style flow).
  mfCentralSyncJobs MFCentralSyncJob[]

  // CAMS + KFintech mailback jobs — free PAN+email driven flow.
  mfCasMailbackJobs MFCasMailbackJob[]

  // F&O (Futures & Options) — broker API credentials + margin snapshots.
  brokerCredentials BrokerCredential[]
  marginSnapshots   MarginSnapshot[]

  // Phase 5-B — vehicle valuation log (per-user audit of saved quotes).
  valuationLogs VehicleValuationLog[]

  // Generic document vault (rental agreements, vehicle RC scans, insurance
  // policy PDFs, …). Reusable across modules via {ownerType, ownerId}.
  documents Document[]

  loans        Loan[]
  creditCards  CreditCard[]
  bankAccounts BankAccount[]

  // Phase 5-RealEstate — owned properties (self-occupied / second home / plot / etc).
  // Distinct from RentalProperty (which models the tenancy/receipts side);
  // see §Property docs.
  ownedProperties OwnedProperty[]

  // Phase 5-PF — EPF / PPF auto-fetch accounts (§6 EPF/PPF spec).
  pfAccounts      ProvidentFundAccount[]
  pfFetchSessions PfFetchSession[]

  // Plan C — browser extension pairing tokens.
  extensionPairings ExtensionPairing[]

  // Phase Gmail-FullInbox — attachment-pivot ingestion pipeline.
  gmailScanJobs         GmailScanJob[]
  gmailDiscoveredDocs   GmailDiscoveredDoc[]
  gmailAutoApproveRules GmailAutoApproveRule[]

  // Forex feature
  forexBalances  ForexBalance[]
  lrsRemittances LrsRemittance[]
  tcsCredits     TcsCredit[]

  // Phase 5-Analytics — persisted AI portfolio insights (cards + narrative).
  portfolioInsights PortfolioInsight[]

  // Phase 2c — user-defined financial goals (retirement / education /
  // home / FIRE / emergency / …). See `Goal` model at end of schema.
  goals Goal[]

  // UI preferences — sidebar asset class order + visibility per user.
  preferences Json?

  // Per-user transactional notification settings (currently SMTP only —
  // SMS provider config can land here too when DLT is sorted).
  notificationConfig UserNotificationConfig?

  // Account Aggregator consents — currently Finfactor (Finvu) only;
  // future AA partners stamp the `provider` column.
  aaConsents AaConsent[]
}

model UserNotificationConfig {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  // SMTP host + port + secure flag. We accept anything the user's
  // mail provider asks for (Gmail, Brevo, SendGrid, Resend, Mailgun,
  // self-hosted Postfix, …) — there's no provider list to choose from.
  smtpHost        String
  smtpPort        Int
  smtpSecure      Boolean  @default(false)
  smtpUser        String
  // Stored AES-256-GCM encrypted via lib/secrets.ts — never returned
  // to the client; the settings endpoint masks it as "***" on read.
  smtpPassEnc     String
  // What the recipient sees as the "From" header. Most providers
  // require the email here to match the authenticated mailbox.
  fromName        String
  fromEmail       String
  // Optional default rent payment instructions for this user. The
  // per-property override on RentalProperty takes precedence when set.
  paymentInstructions String? @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ─── BROKER / DATA-SOURCE CONNECTORS ────────────────────────────

model BrokerAccount {
  id             String          @id @default(cuid())
  userId         String
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolioId    String?
  portfolio      Portfolio?      @relation(fields: [portfolioId], references: [id])
  provider       BrokerProvider
  label          String?
  apiKey         String?
  apiSecretEnc   String?
  accessTokenEnc String?
  publicUserId   String?
  status         ConnectorStatus @default(PENDING)
  lastSyncAt     DateTime?
  lastError      String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([userId])
}

enum BrokerProvider {
  ZERODHA_KITE
  UPSTOX
  ANGEL_ONE
  ICICI_BREEZE
  FIVE_PAISA
  OTHER
}

enum ConnectorStatus {
  PENDING
  CONNECTED
  ERROR
  DISABLED
}

enum MailboxProvider {
  IMAP
  GMAIL_OAUTH
}

model MailboxAccount {
  id              String          @id @default(cuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider        MailboxProvider @default(IMAP)
  label           String?
  host            String?
  port            Int?            @default(993)
  secure          Boolean         @default(true)
  username        String?
  passwordEnc     String?
  refreshTokenEnc String?
  accessTokenEnc  String?
  tokenExpiresAt  DateTime?
  googleEmail     String?
  historyId       String?
  folder          String          @default("INBOX")
  fromFilter      String?
  subjectFilter   String?
  lastPolledAt    DateTime?
  lastError       String?
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  gmailScanJobs GmailScanJob[]

  @@index([userId])
}

enum UserRole {
  INVESTOR
  HNI
  FAMILY_OFFICE
  ADVISOR
  CA
  ADMIN
}

enum PlanTier {
  FREE
  LITE
  PLUS
  HNI
  FAMILY_OFFICE
  ADVISOR
}

model RefreshToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// ─── CLIENTS (for Advisor/CA role) ──────────────────────────────

model Client {
  id        String   @id @default(cuid())
  advisorId String
  advisor   User     @relation(fields: [advisorId], references: [id], onDelete: Cascade)
  name      String
  email     String?
  pan       String?
  phone     String?
  category  String?
  createdAt DateTime @default(now())

  portfolios Portfolio[]

  @@index([advisorId])
}

// ─── PORTFOLIOS & GROUPS ─────────────────────────────────────────

model Portfolio {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  clientId    String?
  client      Client?       @relation(fields: [clientId], references: [id])
  name        String
  description String?
  type        PortfolioType @default(INVESTMENT)
  currency    String        @default("INR")
  isDefault   Boolean       @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  groups          PortfolioGroupMember[]
  holdings        Holding[]
  transactions    Transaction[]
  cashFlows       CashFlow[]
  alerts          Alert[]
  brokerAccounts  BrokerAccount[]
  ownedProperties OwnedProperty[]
  bankAccounts    BankAccount[]

  // Phase 4.5 hardening
  holdingProjections HoldingProjection[]
  canonicalEvents    CanonicalEvent[]

  // F&O (Futures & Options)
  derivativePositions DerivativePosition[]
  expiryCloseJobs     ExpiryCloseJob[]
  portfolioSetting    PortfolioSetting?

  // F&O delivery-equity tax treatment default. Per-transaction override
  // lives on Transaction.equityTaxOverride (null = use this default).
  defaultEquityTaxTreatment EquityTaxTreatment @default(CAPITAL_GAINS)

  // Phase 5-PF — EPF / PPF auto-fetch accounts linked to this portfolio.
  pfAccounts ProvidentFundAccount[]

  // Forex feature
  forexBalances  ForexBalance[]
  lrsRemittances LrsRemittance[]

  // Phase 5-Analytics — per-portfolio AI insights (also nullable on
  // PortfolioInsight for user-level "ALL portfolios" scope).
  portfolioInsights PortfolioInsight[]

  @@index([userId])
  @@index([clientId])
}

enum PortfolioType {
  INVESTMENT
  TRADING
  GOAL
  STRATEGY
}

model PortfolioGroup {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  createdAt   DateTime @default(now())

  members PortfolioGroupMember[]

  @@index([userId])
}

model PortfolioGroupMember {
  portfolioId String
  groupId     String
  portfolio   Portfolio      @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  group       PortfolioGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([portfolioId, groupId])
}

// ─── ASSET MASTER DATA ───────────────────────────────────────────

model StockMaster {
  id        String   @id @default(cuid())
  symbol    String   @unique
  name      String
  exchange  Exchange
  isin      String?  @unique
  sector    String?
  industry  String?
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt

  holdings         Holding[]
  transactions     Transaction[]
  prices           StockPrice[]
  corporateActions CorporateAction[]
}

enum Exchange {
  BSE
  NSE
  MCX
  NFO
  BFO
  NASDAQ
  NYSE
  LSE
  HKEX
  SGX
  TSE
}

model MutualFundMaster {
  id          String     @id @default(cuid())
  schemeCode  String     @unique
  schemeName  String
  amcName     String
  category    MFCategory
  subCategory String?
  isin        String?
  isActive    Boolean    @default(true)
  updatedAt   DateTime   @updatedAt

  holdings     Holding[]
  transactions Transaction[]
  navHistory   MFNav[]
}

enum MFCategory {
  EQUITY
  DEBT
  HYBRID
  SOLUTION_ORIENTED
  OTHER
  ETF
  INDEX_FUND
  ELSS
  FMP
  LIQUID
}

// ─── PRICES ──────────────────────────────────────────────────────

model StockPrice {
  id      String      @id @default(cuid())
  stockId String
  stock   StockMaster @relation(fields: [stockId], references: [id], onDelete: Cascade)
  date    DateTime    @db.Date
  open    Decimal     @db.Decimal(18, 4)
  high    Decimal     @db.Decimal(18, 4)
  low     Decimal     @db.Decimal(18, 4)
  close   Decimal     @db.Decimal(18, 4)
  volume  BigInt?

  @@unique([stockId, date])
  @@index([stockId])
}

model MFNav {
  id     String           @id @default(cuid())
  fundId String
  fund   MutualFundMaster @relation(fields: [fundId], references: [id], onDelete: Cascade)
  date   DateTime         @db.Date
  nav    Decimal          @db.Decimal(18, 4)

  @@unique([fundId, date])
  @@index([fundId])
}

// ─── CORPORATE ACTIONS ───────────────────────────────────────────

model CorporateAction {
  id        String              @id @default(cuid())
  stockId   String
  stock     StockMaster         @relation(fields: [stockId], references: [id], onDelete: Cascade)
  type      CorporateActionType
  exDate    DateTime            @db.Date
  ratio     Decimal?            @db.Decimal(18, 6)
  amount    Decimal?            @db.Decimal(18, 4)
  details   Json?
  createdAt DateTime            @default(now())

  @@index([stockId, exDate])
}

enum CorporateActionType {
  DIVIDEND
  BONUS
  SPLIT
  MERGER
  DEMERGER
  RIGHTS
  BUYBACK
}

// ─── COMMODITY / CRYPTO / FX PRICE FEEDS ─────────────────────────

model CommodityPrice {
  id        String        @id @default(cuid())
  commodity CommodityType
  date      DateTime      @db.Date
  price     Decimal       @db.Decimal(18, 4)
  unit      String        @default("GRAM_24K")
  source    String        @default("IBJA")

  @@unique([commodity, date, unit])
  @@index([commodity, date])
}

enum CommodityType {
  GOLD
  SILVER
  PLATINUM
}

model CryptoMaster {
  id          String        @id @default(cuid())
  coinGeckoId String        @unique
  symbol      String
  name        String
  isActive    Boolean       @default(true)
  updatedAt   DateTime      @updatedAt
  prices      CryptoPrice[]
}

model CryptoPrice {
  id       String       @id @default(cuid())
  cryptoId String
  crypto   CryptoMaster @relation(fields: [cryptoId], references: [id], onDelete: Cascade)
  date     DateTime     @db.Date
  priceInr Decimal      @db.Decimal(24, 8)
  priceUsd Decimal?     @db.Decimal(24, 8)

  @@unique([cryptoId, date])
  @@index([cryptoId, date])
}

model FXRate {
  id       String   @id @default(cuid())
  baseCcy  String
  quoteCcy String
  date     DateTime @db.Date
  rate     Decimal  @db.Decimal(18, 6)
  source   String   @default("RBI")

  @@unique([baseCcy, quoteCcy, date])
  @@index([baseCcy, quoteCcy, date])
}

// ─── FOREX (foreign-currency cash, LRS, TCS) ─────────────────────
//
// ForexBalance models a foreign-currency cash holding outside the
// HoldingProjection engine — it has a single live balance, no FIFO lots.
// FX pair and FOREIGN_EQUITY trades use the standard Transaction model
// (with AssetClass FOREX_PAIR / FOREIGN_EQUITY) and project into
// HoldingProjection like any other tradeable asset.
//
// LRS (Liberalised Remittance Scheme) tracks outward remittance against the
// USD 250k/year RBI ceiling for ITR Schedule FA reporting. TcsCredit tracks
// the 20%-above-7L collected at source so the user can claim it in Form 26AS.

model ForexBalance {
  id               String     @id @default(cuid())
  userId           String
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolioId      String?
  portfolio        Portfolio? @relation(fields: [portfolioId], references: [id])
  currency         String // ISO 4217 e.g. "USD", "EUR"
  balance          Decimal    @db.Decimal(18, 4)
  accountLabel     String? // user-supplied, e.g. "Wise USD"
  accountNumberEnc String? // AES-256-GCM via lib/secrets.ts
  accountLast4     String? // plain, for display
  bankName         String?
  country          String?
  notes            String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  @@unique([userId, currency, accountLabel])
  @@index([userId])
}

model LrsRemittance {
  id             String     @id @default(cuid())
  userId         String
  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolioId    String?
  portfolio      Portfolio? @relation(fields: [portfolioId], references: [id])
  remittanceDate DateTime   @db.Date
  currency       String
  foreignAmount  Decimal    @db.Decimal(18, 4)
  inrEquivalent  Decimal    @db.Decimal(18, 4)
  fxRate         Decimal    @db.Decimal(18, 6)
  purpose        String // "INVESTMENT" | "EDUCATION" | "TRAVEL" | "GIFT" | "MAINTENANCE" | "OTHER"
  bankName       String?
  remittanceRef  String?
  tcsDeducted    Decimal    @default(0) @db.Decimal(18, 4)
  tcsCreditId    String?
  tcsCredit      TcsCredit? @relation(fields: [tcsCreditId], references: [id])
  notes          String?
  createdAt      DateTime   @default(now())

  @@index([userId, remittanceDate])
}

model TcsCredit {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  financialYear String // "2025-26"
  tcsAmount     Decimal  @db.Decimal(18, 4)
  usedAmount    Decimal  @default(0) @db.Decimal(18, 4)
  tan           String?
  collectorName String?
  form27eqRef   String?
  createdAt     DateTime @default(now())

  remittances LrsRemittance[]

  @@index([userId, financialYear])
}

// ─── HOLDINGS ────────────────────────────────────────────────────

model Holding {
  id          String     @id @default(cuid())
  portfolioId String
  portfolio   Portfolio  @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  assetClass  AssetClass

  stockId String?
  stock   StockMaster? @relation(fields: [stockId], references: [id])

  fundId String?
  fund   MutualFundMaster? @relation(fields: [fundId], references: [id])

  assetName String?
  isin      String?

  quantity      Decimal  @db.Decimal(18, 6)
  avgCostPrice  Decimal  @db.Decimal(18, 4)
  totalCost     Decimal  @db.Decimal(18, 4)
  currentPrice  Decimal? @db.Decimal(18, 4)
  currentValue  Decimal? @db.Decimal(18, 4)
  unrealisedPnL Decimal? @db.Decimal(18, 4)

  updatedAt DateTime @updatedAt

  transactions Transaction[]

  @@unique([portfolioId, assetClass, stockId, fundId, isin])
  @@index([portfolioId])
  @@index([stockId])
  @@index([fundId])
}

enum AssetClass {
  EQUITY
  FUTURES
  OPTIONS
  MUTUAL_FUND
  ETF
  BOND
  GOVT_BOND
  CORPORATE_BOND
  FIXED_DEPOSIT
  RECURRING_DEPOSIT
  NPS
  PPF
  EPF
  PMS
  AIF
  REIT
  INVIT
  GOLD_BOND
  GOLD_ETF
  PHYSICAL_GOLD
  PHYSICAL_SILVER
  ULIP
  INSURANCE
  REAL_ESTATE
  PRIVATE_EQUITY
  CRYPTOCURRENCY
  ART_COLLECTIBLES
  CASH
  OTHER
  NSC
  KVP
  SCSS
  SSY
  POST_OFFICE_MIS
  POST_OFFICE_RD
  POST_OFFICE_TD
  POST_OFFICE_SAVINGS
  FOREIGN_EQUITY
  FOREX_PAIR
}

// ─── TRANSACTIONS ─────────────────────────────────────────────────

model Transaction {
  id          String    @id @default(cuid())
  portfolioId String
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  holdingId   String?
  holding     Holding?  @relation(fields: [holdingId], references: [id])

  assetClass      AssetClass
  transactionType TransactionType

  stockId   String?
  stock     StockMaster?      @relation(fields: [stockId], references: [id])
  fundId    String?
  fund      MutualFundMaster? @relation(fields: [fundId], references: [id])
  assetName String?
  isin      String?

  tradeDate      DateTime  @db.Date
  settlementDate DateTime? @db.Date
  quantity       Decimal   @db.Decimal(18, 6)
  price          Decimal   @db.Decimal(18, 4)
  grossAmount    Decimal   @db.Decimal(18, 4)

  brokerage       Decimal @default(0) @db.Decimal(18, 4)
  stt             Decimal @default(0) @db.Decimal(18, 4)
  stampDuty       Decimal @default(0) @db.Decimal(18, 4)
  exchangeCharges Decimal @default(0) @db.Decimal(18, 4)
  gst             Decimal @default(0) @db.Decimal(18, 4)
  sebiCharges     Decimal @default(0) @db.Decimal(18, 4)
  otherCharges    Decimal @default(0) @db.Decimal(18, 4)
  netAmount       Decimal @db.Decimal(18, 4)

  strikePrice Decimal?    @db.Decimal(18, 4)
  expiryDate  DateTime?   @db.Date
  optionType  OptionType?
  lotSize     Int?

  maturityDate      DateTime? @db.Date
  interestRate      Decimal?  @db.Decimal(8, 4)
  interestFrequency String?

  broker    String?
  exchange  Exchange?
  orderNo   String?
  tradeNo   String?
  narration String?

  importJobId String?
  importJob   ImportJob? @relation(fields: [importJobId], references: [id])

  // Forex feature: native currency + rate frozen at trade time (tax basis).
  // currency = null means INR (backward compat). fxRateAtTrade is the
  // base→INR rate at tradeDate; inrEquivalent is the INR value of grossAmount
  // (or netAmount, depending on caller) at that rate. Nullable to preserve
  // existing INR-only rows.
  currency      String?
  fxRateAtTrade Decimal? @db.Decimal(18, 6)
  inrEquivalent Decimal? @db.Decimal(18, 4)

  // Phase 4.5 hardening (§4.5): idempotency + parser lineage + asset identity.
  // assetKey starts nullable for backfill; a follow-up migration flips it to
  // NOT NULL after the UPDATE in 20260421_phase_4_5_hardening completes.
  // sourceHash is nullable because manually-entered rows predate it.
  assetKey         String?
  sourceAdapter    String?
  sourceAdapterVer String?
  sourceHash       String?         @unique
  canonicalEventId String?
  canonicalEvent   CanonicalEvent? @relation("CanonicalEventToTransaction", fields: [canonicalEventId], references: [id])

  // F&O — per-transaction override of Portfolio.defaultEquityTaxTreatment.
  // null = inherit from portfolio. Only meaningful for delivery EQUITY/ETF;
  // F&O is always BUSINESS_INCOME via foPnl.service (intraday=speculative).
  equityTaxOverride EquityTaxTreatment?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  capitalGains   CapitalGain[]
  voucherEntries VoucherEntry[]
  photos         TransactionPhoto[]

  @@index([portfolioId, tradeDate])
  @@index([stockId])
  @@index([fundId])
  @@index([importJobId])
  @@index([portfolioId, assetKey])
  @@index([sourceAdapter, sourceAdapterVer])
}

model TransactionPhoto {
  id            String      @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  fileName      String
  filePath      String
  mimeType      String
  sizeBytes     Int

  createdAt DateTime @default(now())

  @@index([transactionId])
}

enum TransactionType {
  BUY
  SELL
  SWITCH_IN
  SWITCH_OUT
  SIP
  DIVIDEND_REINVEST
  DIVIDEND_PAYOUT
  BONUS
  SPLIT
  MERGER_IN
  MERGER_OUT
  DEMERGER_IN
  DEMERGER_OUT
  RIGHTS_ISSUE
  INTEREST_RECEIVED
  MATURITY
  REDEMPTION
  DEPOSIT
  WITHDRAWAL
  OPENING_BALANCE
}

enum OptionType {
  CALL
  PUT
}

// ─── CAPITAL GAINS ────────────────────────────────────────────────

model CapitalGain {
  id                String      @id @default(cuid())
  portfolioId       String
  sellTransactionId String
  sellTransaction   Transaction @relation(fields: [sellTransactionId], references: [id], onDelete: Cascade)

  buyTransactionId String
  assetClass       AssetClass
  assetName        String
  isin             String?

  buyDate    DateTime @db.Date
  sellDate   DateTime @db.Date
  quantity   Decimal  @db.Decimal(18, 6)
  buyPrice   Decimal  @db.Decimal(18, 4)
  sellPrice  Decimal  @db.Decimal(18, 4)
  buyAmount  Decimal  @db.Decimal(18, 4)
  sellAmount Decimal  @db.Decimal(18, 4)

  indexedCostOfAcquisition Decimal? @db.Decimal(18, 4)

  capitalGainType CapitalGainType
  gainLoss        Decimal         @db.Decimal(18, 4)
  taxableGain     Decimal         @db.Decimal(18, 4)
  financialYear   String

  createdAt DateTime @default(now())

  @@index([portfolioId, financialYear])
  @@index([sellTransactionId])
}

enum CapitalGainType {
  INTRADAY
  SHORT_TERM
  LONG_TERM
}

// ─── CASH FLOWS ───────────────────────────────────────────────────

model CashFlow {
  id            String       @id @default(cuid())
  portfolioId   String
  portfolio     Portfolio    @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  date          DateTime     @db.Date
  type          CashFlowType
  amount        Decimal      @db.Decimal(18, 4)
  description   String?
  // Forex: native currency + INR equivalent for foreign-currency cash moves.
  // null currency means INR.
  currency      String?
  inrEquivalent Decimal?     @db.Decimal(18, 4)
  createdAt     DateTime     @default(now())

  // Optional attribution to a bank account. Set automatically when projecting
  // a CanonicalEvent whose accountLast4 matches a known BankAccount.last4 for
  // the user; nullable for manual cashflows that don't track an account.
  bankAccountId String?
  bankAccount   BankAccount? @relation(fields: [bankAccountId], references: [id], onDelete: SetNull)

  @@index([portfolioId, date])
  @@index([bankAccountId, date])
}

enum CashFlowType {
  INFLOW
  OUTFLOW
}

// ─── ACCOUNTING MODULE ────────────────────────────────────────────

model Account {
