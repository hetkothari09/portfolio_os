  userId         String
  user           User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  code           String
  name           String
  type           AccountType
  parentId       String?
  parent         Account?    @relation("AccountTree", fields: [parentId], references: [id])
  children       Account[]   @relation("AccountTree")
  openingBalance Decimal     @default(0) @db.Decimal(18, 4)
  createdAt      DateTime    @default(now())

  debitEntries  VoucherEntry[] @relation("DebitAccount")
  creditEntries VoucherEntry[] @relation("CreditAccount")

  @@unique([userId, code])
  @@index([userId])
}

enum AccountType {
  ASSET
  LIABILITY
  INCOME
  EXPENSE
  EQUITY
}

model Voucher {
