// ─── PHASE 4.5 HARDENING — §4.1 CANONICAL INGESTION LAYER ────────
//
// All ingested events — from Gmail, CAS, contract notes, bank feeds, vehicle
// portals — land here first as a canonical record before being projected into
// Transaction / CashFlow / PremiumPayment / RentReceipt. Idempotency is
// enforced by the (userId, sourceHash) unique constraint (§3.3, BUG-003).

model CanonicalEvent {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolioId String?
  portfolio   Portfolio? @relation(fields: [portfolioId], references: [id])

  sourceAdapter    String
  sourceAdapterVer String
  sourceRef        String
  sourceHash       String
  senderAddress    String?

  eventType        CanonicalEventType
  eventDate        DateTime           @db.Date
  amount           Decimal?           @db.Decimal(18, 4)
  quantity         Decimal?           @db.Decimal(18, 6)
  price            Decimal?           @db.Decimal(18, 4)
  counterparty     String?
  instrumentIsin   String?
  instrumentSymbol String?
  instrumentName   String?
  accountLast4     String?
  currency         String             @default("INR")
  metadata         Json?
  confidence       Decimal            @default(1.00) @db.Decimal(3, 2)
  parserNotes      String?

  status                 CanonicalEventStatus @default(PARSED)
  reviewedById           String?
  reviewedAt             DateTime?
  projectedTransactionId String?
  projectedCashFlowId    String?
  rejectionReason        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectedTransactions Transaction[] @relation("CanonicalEventToTransaction")

  @@unique([userId, sourceHash])
  @@index([userId, status, eventDate])
  @@index([userId, senderAddress])
  @@index([sourceAdapter, sourceAdapterVer])
}

enum CanonicalEventType {
  BUY
  SELL
  DIVIDEND
  INTEREST_CREDIT
  INTEREST_DEBIT
  EMI_DEBIT
  PREMIUM_PAID
  MATURITY_CREDIT
  RENT_RECEIVED
  RENT_PAID
  SIP_INSTALLMENT
  FD_CREATION
  FD_MATURITY
  CARD_PURCHASE
  CARD_PAYMENT
  UPI_CREDIT
  UPI_DEBIT
  NEFT_CREDIT
  NEFT_DEBIT
  VALUATION_SNAPSHOT
  VEHICLE_CHALLAN
  FNO_TRADE
  FNO_EXPIRY_CLOSE
  FNO_EXERCISE
  FNO_ASSIGNMENT
  FNO_ROLLOVER
  PF_EMPLOYER_CONTRIBUTION
  PF_EMPLOYEE_CONTRIBUTION
  PF_VPF_CONTRIBUTION
  PF_INTEREST_CREDIT
  PF_WITHDRAWAL
  PF_TRANSFER_IN
  PF_TRANSFER_OUT
  PF_OPENING_BALANCE
  OTHER
}

enum CanonicalEventStatus {
  PARSED
  PENDING_REVIEW
  CONFIRMED
  PROJECTED
  REJECTED
  FAILED
  ARCHIVED
}

// ─── §4.2 MONITORED SENDERS + LEARNED TEMPLATES ──────────────────
//
// User-chosen Gmail addresses the poller should fetch (§6.7); LearnedTemplate
// is the regex/xpath recipe promoted from LLM-parsed samples once the
// (sender, bodyStructureHash) has enough agreeing extractions to be cheap to
// re-run without the LLM (§6.4).

model MonitoredSender {
  id                  String           @id @default(cuid())
  userId              String
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  address             String
  displayLabel        String?
  isActive            Boolean          @default(true)
  autoCommitAfter     Int              @default(5)
  autoCommitEnabled   Boolean          @default(false)
  confirmedEventCount Int              @default(0)
  currentTemplateId   String?
  template            LearnedTemplate? @relation(fields: [currentTemplateId], references: [id])
  firstSeenAt         DateTime         @default(now())
  lastFetchedAt       DateTime?

  @@unique([userId, address])
  @@index([userId, isActive])
}

model LearnedTemplate {
  id                String    @id @default(cuid())
  userId            String
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  senderAddress     String
  bodyStructureHash String
  extractionRecipe  Json
  sampleCount       Int       @default(1)
  confidenceScore   Decimal   @default(0.00) @db.Decimal(3, 2)
  version           Int       @default(1)
  isActive          Boolean   @default(true)
  createdAt         DateTime  @default(now())
  lastUsedAt        DateTime?

  monitoredSenders MonitoredSender[]

  @@unique([userId, senderAddress, bodyStructureHash, version])
}

// ─── §6.10 PRE-SEEDED SENDER DIRECTORY ───────────────────────────
//
// Shared reference table (NOT user-scoped) shipped with the Phase
// 5-A release. Maps known financial-institution sender addresses to
// human-readable metadata so that:
//   1. The §6.6 discovery UI can label "alerts@hdfcbank.net" as
//      "HDFC Bank" without the user typing anything.
//   2. When a user adopts a MonitoredSender that matches a seed, the
//      seed's display label / suggested threshold auto-fill.
//
// Unlike `LearnedTemplate`, a seed row carries NO extractionRecipe —
// that's learned from actual email samples via §6.4 promotion. A
// seed is metadata only; the parse path is still LLM-on-first-sight.

model TemplateSeed {
  id                       String          @id @default(cuid())
  address                  String          @unique
  institutionName          String
  institutionKind          InstitutionKind
  suggestedDisplayLabel    String
  suggestedAutoCommitAfter Int             @default(5)
  isActive                 Boolean         @default(true)
  notes                    String?
  createdAt                DateTime        @default(now())
}

enum InstitutionKind {
  BANK
  BROKER
  INSURER
  REGISTRAR
}

// ─── §4.3 INGESTION DLQ ──────────────────────────────────────────
//
// Parse failures never crash the job (§3.5, BUG-006). Raw payload is
// redacted per §15.9 before being stored here.

model IngestionFailure {
  id             String    @id @default(cuid())
  userId         String
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceAdapter  String
  adapterVersion String
  sourceRef      String
  errorMessage   String
  errorStack     String?
  rawPayload     Json?
  resolvedAt     DateTime?
  resolvedAction String?
  createdAt      DateTime  @default(now())

  pfFetchSessions PfFetchSession[]

  @@index([userId, resolvedAt])
}

// ─── §4.4 HOLDINGS AS PROJECTION ─────────────────────────────────
//
// Computed by replaying Transaction + CorporateAction through the FIFO engine.
// Mutated only by recomputeForAsset (§5.1 task 4); never by any write path
// except the projection service (§3.1, BUG-002). The legacy Holding table
// stays read-only for one release after parity is confirmed (§4.10 step 6).

model HoldingProjection {
  id            String     @id @default(cuid())
  portfolioId   String
  portfolio     Portfolio  @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  assetKey      String
  assetClass    AssetClass
  stockId       String?
  fundId        String?
  assetName     String?
  isin          String?
  quantity      Decimal    @db.Decimal(18, 6)
  avgCostPrice  Decimal    @db.Decimal(18, 4)
  totalCost     Decimal    @db.Decimal(18, 4)
  currentPrice  Decimal?   @db.Decimal(18, 4)
  currentValue  Decimal?   @db.Decimal(18, 4)
  unrealisedPnL Decimal?   @db.Decimal(18, 4)
  realisedPnL   Decimal    @default(0) @db.Decimal(18, 4)
  // Date of the market price used for currentValue. Null for accrual/cost
  // assets (no market feed). Drives the stale-price badge (isPriceStale).
  priceAsOf     DateTime?
  computedAt    DateTime   @default(now())
  sourceTxCount Int

  @@unique([portfolioId, assetKey])
  @@index([portfolioId, assetClass])
}

// ─── §4.6 VEHICLES + CHALLANS ────────────────────────────────────

model Vehicle {
  id                 String    @id @default(cuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolioId        String?
  registrationNo     String
  make               String?
  model              String?
  variant            String?
  manufacturingYear  Int?
  fuelType           String?
  color              String?
  chassisLast4       String?
  rtoCode            String?
  ownerName          String?
  purchaseDate       DateTime? @db.Date
  purchasePrice      Decimal?  @db.Decimal(14, 2)
  currentValue       Decimal?  @db.Decimal(14, 2)
  currentValueSource String?
  insuranceExpiry    DateTime? @db.Date
  insurancePolicyId  String?
  pucExpiry          DateTime? @db.Date
  fitnessExpiry      DateTime? @db.Date
  roadTaxExpiry      DateTime? @db.Date
  permitExpiry       DateTime? @db.Date
  // ── Promoted from metadata blob: surfaced in UI dashboard ──
  rcStatus           String? // ACTIVE | SUSPENDED | CANCELLED
  vehicleClass       String? // "M-CYCLE/SCOOTER" | "LMV" | etc.
  normsType          String? // "BS-VI" | etc.
  seatingCapacity    Int?
  unloadedWeight     Int? // kg
  engineNo           String?
  hypothecation      String? // financier name or "NONE"
  registrationDate   DateTime? @db.Date
  // ── Stock photo (make+model lookup) ──
  photoUrl           String?
  photoSource        String? // "carDekho" | "catalog" | "user-upload" | "stock-generic"
  lastRefreshedAt    DateTime?
  refreshSource      String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  challans          Challan[]
  insurancePolicies InsurancePolicy[]     @relation("VehicleInsurance")
  valuationLogs     VehicleValuationLog[]
  loans             Loan[]

  @@unique([userId, registrationNo])
  @@index([userId, insuranceExpiry])
  @@index([userId, pucExpiry])
}

// Stock vehicle photos keyed by (make, model). Seeded once from CarDekho.
// Looked up at refresh time to populate Vehicle.photoUrl.
model VehiclePhotoSeed {
  id                String   @id @default(cuid())
  make              String
  model             String
  variant           String?
  bodyType          String? // sedan | suv | hatchback | mpv | bike | scooter
  photoUrl          String
  sourceAttribution String   @default("carDekho")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([make, model, variant])
  @@index([make, model])
}

model Challan {
  id          String   @id @default(cuid())
  vehicleId   String
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  challanNo   String
  offenceDate DateTime @db.Date
  offenceType String?
  location    String?
  amount      Decimal  @db.Decimal(10, 2)
  status      String
  details     Json?
  fetchedAt   DateTime @default(now())

  @@unique([vehicleId, challanNo])
}

// ─── §7-VALUATION — OBV-style used-vehicle valuation ─────────────────

// Master catalog of (category, make, model, year, trim). Seeded from
// Kaggle dataset, refreshed monthly from CarDekho/CarWale scrape.
// Shared across users — not user-scoped.
model VehicleCatalog {
  id            String   @id @default(cuid())
  category      String // Hatchback | Sedan | SUV | MUV | Coupe | Convertible | Bike | Scooter
  make          String
  model         String
  yearFrom      Int
  yearTo        Int?
  trim          String
  baseMsrp      Decimal? @db.Decimal(14, 2)
  fuelType      String?
  bodyType      String?
  displacement  Int?
  seatingCap    Int?
  photoUrl      String?
  catalogSource String // cardekho | carwale | kaggle | manual
  isActive      Boolean  @default(true)
  lastSyncedAt  DateTime @default(now())

  @@unique([make, model, trim, yearFrom])
  @@index([category, make])
  @@index([make, model])
}

// 24h cache of valuation quote per (make+model+year+trim+kmsBucket+txnType+partyType).
// Result is shared across users — cacheKey is deterministic.
model VehicleValuation {
  id        String @id @default(cuid())
  cacheKey  String @unique
  make      String
  model     String
  year      Int
  trim      String
  kmsBucket Int // kms rounded to nearest 5000
  txnType   String // BUY | SELL
  partyType String // INDIVIDUAL | DEALER

  priceBad       Decimal @db.Decimal(14, 2)
  priceFair      Decimal @db.Decimal(14, 2)
  priceGood      Decimal @db.Decimal(14, 2)
  priceVeryGood  Decimal @db.Decimal(14, 2)
  priceExcellent Decimal @db.Decimal(14, 2)

  future1y      Decimal @db.Decimal(14, 2)
  future3y      Decimal @db.Decimal(14, 2)
  future5y      Decimal @db.Decimal(14, 2)
  residualValue Decimal @db.Decimal(14, 2)
  salvageValue  Decimal @db.Decimal(14, 2)
  clunkerValue  Decimal @db.Decimal(14, 2)

  sources     Json
  isEstimated Boolean  @default(false)
  computedAt  DateTime @default(now())
  expiresAt   DateTime

  logs VehicleValuationLog[]

  @@index([make, model, year])
  @@index([expiresAt])
}

// Per-user audit trail of saved quotes + slider snapshot.
model VehicleValuationLog {
  id             String           @id @default(cuid())
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  vehicleId      String?
  vehicle        Vehicle?         @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  valuationId    String
  valuation      VehicleValuation @relation(fields: [valuationId], references: [id], onDelete: Cascade)
  sliderSnapshot Json
  adjustedPrice  Decimal          @db.Decimal(14, 2)
  txnType        String
  partyType      String
  savedToVehicle Boolean          @default(false)
  createdAt      DateTime         @default(now())

  @@index([userId, createdAt])
  @@index([vehicleId])
}

// ─── §4.7 RENTAL ─────────────────────────────────────────────────

model RentalProperty {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolioId   String?
  name          String
  address       String?
  propertyType  String
  purchaseDate  DateTime? @db.Date
  purchasePrice Decimal?  @db.Decimal(14, 2)
  currentValue  Decimal?  @db.Decimal(14, 2)
  isActive      Boolean   @default(true)
  // Per-property landlord display name (signed on rent reminders). Falls
  // back to the user's profile name if blank.
  landlordName  String?
  // Per-property payment instructions (UPI handle, NEFT details, etc.)
  // shown in rent reminder emails. Falls back to
  // UserNotificationConfig.paymentInstructions if blank.
  paymentInstructions String? @db.Text
  createdAt     DateTime  @default(now())

  tenancies       Tenancy[]
  expenses        PropertyExpense[]
  loans           Loan[]
  ownedProperties OwnedProperty[]
}

model Tenancy {
  id              String         @id @default(cuid())
  propertyId      String
  property        RentalProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenantName      String
  // Legacy single-line contact (free text). Retained for back-compat with
  // tenancies created before tenantEmail/tenantPhone were split out.
  tenantContact   String?
  tenantEmail     String?
  tenantPhone     String?
  startDate       DateTime       @db.Date
  endDate         DateTime?      @db.Date
  monthlyRent     Decimal        @db.Decimal(12, 2)
  securityDeposit Decimal?       @db.Decimal(12, 2)
  rentDueDay      Int            @default(1)
  isActive        Boolean        @default(true)
  notes           String?
  createdAt       DateTime       @default(now())

  rentReceipts RentReceipt[]
  reminders    RentReminder[]

  @@index([propertyId, isActive])
}

model RentReceipt {
  id                     String    @id @default(cuid())
  tenancyId              String
  tenancy                Tenancy   @relation(fields: [tenancyId], references: [id], onDelete: Cascade)
  forMonth               String
  expectedAmount         Decimal   @db.Decimal(12, 2)
  receivedAmount         Decimal?  @db.Decimal(12, 2)
  dueDate                DateTime  @db.Date
  receivedOn             DateTime? @db.Date
  status                 String
  cashFlowId             String?
  notes                  String?
  autoMatchedFromEventId String?

  reminders RentReminder[]

  @@unique([tenancyId, forMonth])
  @@index([dueDate, status])
}

// Tenant rent reminder queue. The cron creates one row per (receipt,
// leadDays) tuple as the due date approaches. Each row starts in
// PENDING_APPROVAL — the landlord reviews + optionally edits the
// subject/body in the UI, then either approves (which triggers the
// actual SMS + email send) or rejects. No auto-send: every outbound
// message is a deliberate human action.
model RentReminder {
  id          String   @id @default(cuid())
  receiptId   String
  receipt     RentReceipt @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  tenancyId   String
  tenancy     Tenancy  @relation(fields: [tenancyId], references: [id], onDelete: Cascade)

  // Days before dueDate this reminder was queued for: 5 / 3 / 1 / 0
  // (0 = same-day). Multiple rows per receipt — one per lead day —
  // dedup-protected by the unique constraint below.
  leadDays    Int

  // PENDING_APPROVAL | APPROVED | SENT | FAILED | REJECTED | SUPERSEDED
  // SUPERSEDED = receipt was marked RECEIVED before approval, no longer needed.
  status      String   @default("PENDING_APPROVAL")

  // Channels the landlord wants to send through. {email: true, sms: true}.
  channels    Json

  // Editable message content (cron pre-fills via template).
  subject     String
  body        String   @db.Text
  smsBody     String   @db.Text

  // Per-channel send result. "skipped" when channel disabled or
  // recipient missing; "sent" / "failed" otherwise.
  emailStatus String?
  emailError  String?
  smsStatus   String?
  smsError    String?

  createdAt   DateTime @default(now())
  approvedAt  DateTime?
  sentAt      DateTime?

  @@unique([receiptId, leadDays])
  @@index([status, createdAt])
  @@index([tenancyId, status])
}

model PropertyExpense {
  id          String         @id @default(cuid())
  propertyId  String
  property    RentalProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  expenseType String
  amount      Decimal        @db.Decimal(12, 2)
  paidOn      DateTime       @db.Date
  description String?
  receiptUrl  String?
}

