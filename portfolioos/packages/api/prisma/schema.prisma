enum EquityTaxTreatment {
  CAPITAL_GAINS
  BUSINESS_INCOME
}

// ─── DOCUMENT VAULT ────────────────────────────────────────────────
//
// Generic per-user document store, polymorphically attached to any owning
// module via (ownerType, ownerId). Files live on disk under
// ${UPLOAD_DIR}/user_${userId}/${storageKey}.${ext} per BUG-015. Access is
// always proxied through an authenticated download endpoint that verifies
// userId — files are never served via static path.
//
// `externalEditKey` is opaque to the rest of the system: it's the document
// identifier passed to OnlyOffice DocumentServer. Bumped every time the
// stored bytes change so OnlyOffice's internal cache invalidates.

model Document {
  id              String            @id @default(cuid())
  userId          String
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  ownerType       DocumentOwnerType
  ownerId         String
  category        String? // free-text label, e.g. "agreement", "receipt"
  fileName        String // original-or-edited display name
  mimeType        String
  sizeBytes       Int
  storageKey      String            @unique // uuid filename relative to user dir
  externalEditKey String            @unique // OnlyOffice "key" — bump on save
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([userId, ownerType, ownerId])
  @@index([userId, createdAt])
}

enum DocumentOwnerType {
  RENTAL_PROPERTY
  TENANCY
  VEHICLE
  INSURANCE_POLICY
  PORTFOLIO
  OWNED_PROPERTY
  OTHER
}

// ─── LOANS ────────────────────────────────────────────────────────

