// ─── BANK ACCOUNTS ─────────────────────────────────────────────────
//
// First-class entity (parallel to CreditCard) rather than a CASH-class
// Holding — bank metadata (IFSC, branch, nominee, joint holders, debit
// card linkage) doesn't fit the Holding shape. Balances are tracked via
// a current snapshot on the row plus a BankBalanceSnapshot history so
// the detail page can chart balance-over-time. Auto-attribution from
// Gmail/statement-derived CanonicalEvents happens by matching the
// event's accountLast4 against this user's accounts.

model BankAccount {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolioId String?
  portfolio   Portfolio? @relation(fields: [portfolioId], references: [id])

  // Core identity — last 4 digits only; no full-PAN/account-no storage.
  bankName      String // "HDFC Bank"
  accountType   String // SAVINGS | CURRENT | SALARY | NRE | NRO | OD
  accountHolder String
  last4         String // last 4 digits of the account number
  ifsc          String?
  branch        String?
  nickname      String? // user-given label e.g. "Primary salary"

  // Joint holder / nominee
  jointHolders    String[] @default([])
  nomineeName     String?
  nomineeRelation String?

  // Linked debit card
  debitCardLast4  String?
  debitCardExpiry String? // MM/YY

  // Balance
  currentBalance Decimal?  @db.Decimal(14, 2)
  balanceAsOf    DateTime?
  balanceSource  String? // "manual" | "statement" | "auto_event"

  // Lifecycle
  status    String    @default("ACTIVE") // ACTIVE | DORMANT | CLOSED
  openedOn  DateTime? @db.Date
  closedOn  DateTime? @db.Date
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  snapshots BankBalanceSnapshot[]
  cashFlows CashFlow[]

  @@unique([userId, bankName, last4])
  @@index([userId, status])
}

model BankBalanceSnapshot {
  id               String      @id @default(cuid())
  accountId        String
  account          BankAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  asOfDate         DateTime    @db.Date
  balance          Decimal     @db.Decimal(14, 2)
  source           String // "manual" | "statement_upload" | "auto_event"
  canonicalEventId String?
  note             String?
  createdAt        DateTime    @default(now())

  @@unique([accountId, asOfDate])
  @@index([accountId, asOfDate])
}

// ─── REAL ESTATE — Owned properties ─────────────────────────────────────
//
// Tracks properties the user owns (self-occupied / second home / vacant
// plot / commercial / under-construction / sold). Distinct from
// `RentalProperty` which models the tenancy/receipts side. The same
// physical property may exist as both rows when it's both owned and
// rented out — link via `rentalPropertyId`.
//
// Capital gains on sale (LTCG with CII indexation under section 112)
// are computed on demand from the stored sale fields; no separate
// CapitalGain row is written until the accounting flow integrates.

model OwnedProperty {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolioId String?
  portfolio   Portfolio? @relation(fields: [portfolioId], references: [id])

  // Identity
  name    String
  address String?
  city    String?
  state   String?
  pincode String?
  country String  @default("IN")

  propertyType String // APARTMENT|INDEPENDENT_HOUSE|VILLA|PLOT_LAND|COMMERCIAL_OFFICE|COMMERCIAL_SHOP|AGRICULTURAL|PARKING_GARAGE|UNDER_CONSTRUCTION|OTHER
  status       String @default("SELF_OCCUPIED") // SELF_OCCUPIED|SECOND_HOME|VACANT|RENTED_OUT|UNDER_CONSTRUCTION|SOLD

  // Specs
  builtUpSqft  Decimal? @db.Decimal(12, 2)
  carpetSqft   Decimal? @db.Decimal(12, 2)
  plotAreaSqft Decimal? @db.Decimal(12, 2)
  floors       Int?

  // Ownership
  ownershipType    String  @default("SOLE") // SOLE|JOINT|HUF|COMPANY
  ownershipPercent Decimal @default(100) @db.Decimal(5, 2)
  coOwners         String?

  // Purchase cost components — total cost basis = sum
  purchaseDate    DateTime? @db.Date
  purchasePrice   Decimal?  @db.Decimal(14, 2)
  stampDuty       Decimal?  @db.Decimal(14, 2)
  registrationFee Decimal?  @db.Decimal(14, 2)
  brokerage       Decimal?  @db.Decimal(14, 2)
  otherCosts      Decimal?  @db.Decimal(14, 2)

  // Current value (manual; refresh prompt in UI when stale)
  currentValue       Decimal?  @db.Decimal(14, 2)
  currentValueSource String?   @default("manual")
  currentValueAsOf   DateTime?

  // Linkages — proper FKs (fixes loans pattern of bare string IDs)
  loanId            String?
  loan              Loan?            @relation(fields: [loanId], references: [id])
  insurancePolicyId String?
  insurancePolicy   InsurancePolicy? @relation(fields: [insurancePolicyId], references: [id])
  rentalPropertyId  String?
  rentalProperty    RentalProperty?  @relation(fields: [rentalPropertyId], references: [id])

  // Property tax + society
  annualPropertyTax    Decimal? @db.Decimal(12, 2)
  propertyTaxDueMonth  Int? // 1-12
  societyName          String?
  monthlyMaintenance   Decimal? @db.Decimal(10, 2)
  maintenanceFrequency String?  @default("MONTHLY") // MONTHLY|QUARTERLY|ANNUAL

  // Identifiers
  ownerName             String?
  electricityConsumerNo String?
  waterConnectionNo     String?
  gasConnectionNo       String?
  khataNo               String?
  surveyNo              String?

  // Under construction
  builderName            String?
  projectName            String?
  reraRegNo              String?
  expectedPossessionDate DateTime? @db.Date
  paymentSchedulePaidPct Decimal?  @db.Decimal(5, 2)

  // Lease
  leaseholdEndDate DateTime? @db.Date

  // Sale
  saleDate      DateTime? @db.Date
  salePrice     Decimal?  @db.Decimal(14, 2)
  saleBrokerage Decimal?  @db.Decimal(14, 2)

  notes    String?
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, status])
  @@index([userId, propertyTaxDueMonth])
  @@index([userId, expectedPossessionDate])
}

// ─── §6 PROVIDENT FUND AUTO-FETCH ──────────────────────────────────────────

enum PfType {
  EPF
  PPF
}

enum PfInstitution {
  EPFO
  SBI
  INDIA_POST
  HDFC
  ICICI
  AXIS
  PNB
  BOB
}

enum PfAccountStatus {
  ACTIVE
  NEEDS_REAUTH
  LOCKED
  INSTITUTION_CHANGED
}

enum PfFetchSource {
  EXTENSION
  SERVER_HEADLESS
  MANUAL_PDF
}

enum PfFetchStatus {
  INITIATED
  AWAITING_CAPTCHA
  AWAITING_OTP
  SCRAPING
  PARSING
  COMPLETED
  FAILED
  CANCELLED
}

model ProvidentFundAccount {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id])
  portfolioId String?
  portfolio   Portfolio? @relation(fields: [portfolioId], references: [id])

  type              PfType
  institution       PfInstitution
  identifierCipher  Bytes
  identifierLast4   String
  holderName        String
  branchCode        String?
  /// Encrypted credential blob written by `pfCredentials.service.ts`.
  /// Shape: { blob: string }  where `blob` is AES-256-GCM ciphertext (base64).
  /// NEVER write plaintext credentials here. The application layer is responsible.
  storedCredentials Json?
  credentialsKeyId  String?

  status          PfAccountStatus @default(ACTIVE)
  lastRefreshedAt DateTime?
  lastFetchSource PfFetchSource?

  /// When the most recent stale-account nudge alert was emitted (null = never).
  lastNudgedAt      DateTime?
  /// User-set future date until which nudges should be suppressed (null = no snooze).
  nudgeSnoozedUntil DateTime?

  currentBalance Decimal? @db.Decimal(18, 4)
  assetKey       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberIds     EpfMemberId[]
  fetchSessions PfFetchSession[]

  @@unique([userId, assetKey])
  @@index([userId, status, lastRefreshedAt])
}

model EpfMemberId {
  id                     String               @id @default(cuid())
  providentFundAccountId String
  account                ProvidentFundAccount @relation(fields: [providentFundAccountId], references: [id], onDelete: Cascade)

  memberIdCipher           Bytes
  memberIdLast4            String
  establishmentName        String
  establishmentCode        String?
  dateOfJoining            DateTime? @db.Date
  dateOfExit               DateTime? @db.Date
  currentBalance           Decimal?  @db.Decimal(18, 4)
  lastInterestUpdatedForFY String?

  @@unique([providentFundAccountId, memberIdLast4])
}

model PfFetchSession {
  id                     String               @id @default(cuid())
  providentFundAccountId String
  account                ProvidentFundAccount @relation(fields: [providentFundAccountId], references: [id], onDelete: Cascade)
  userId                 String
  user                   User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  source             PfFetchSource
  status             PfFetchStatus     @default(INITIATED)
  startedAt          DateTime          @default(now())
  completedAt        DateTime?
  captchaAttempts    Int               @default(0)
  ocrUsed            Boolean           @default(false)
  ocrSucceeded       Boolean?
  rawPayloadRef      String?
  eventsCreated      Int               @default(0)
  errorMessage       String?
  ingestionFailureId String?
  ingestionFailure   IngestionFailure? @relation(fields: [ingestionFailureId], references: [id], onDelete: SetNull)

  @@index([providentFundAccountId, startedAt])
  @@index([userId, status])
}

// ─── §Plan-C EXTENSION PAIRING ───────────────────────────────────────────────
//
// Links a browser extension install to a user account via a short-lived pairing
// code. After exchange, the extension holds a long-lived bearer token; the server
// stores only SHA-256(bearer) for indexed verification — the plaintext is never
// stored server-side (bearer is opaque random bytes; we only need to verify).
// `bearerLast8` stores the last 8 hex chars of the bearer for display in the
// pairings list without revealing the full secret.
//
// Decision (per plan §C1): store only `bearerHash` (SHA-256), not an encrypted
// copy. This is cleaner and sufficient because we never need to recover the
// bearer plaintext on the server.

model ExtensionPairing {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// Short-lived 8-char human-readable code, e.g. "XK7-9MQ2". Unique + TTL-checked.
  pairingCode          String   @unique
  pairingCodeExpiresAt DateTime

  /// SHA-256(bearer) — used for O(1) bearer lookup. Never stores plaintext.
  bearerHash  String? @unique
  /// Last 8 hex chars of the bearer for display purposes.
  bearerLast8 String?

  paired     Boolean   @default(false)
  pairedAt   DateTime?
  lastUsedAt DateTime?
  revoked    Boolean   @default(false)
  revokedAt  DateTime?

  createdAt DateTime @default(now())

  @@index([userId, paired])
  @@index([userId, revoked])
}

// ─── PHASE 2c — FINANCIAL GOALS ───────────────────────────────────
//
// User-defined targets (retirement, child education, FIRE corpus, home
// down-payment, emergency fund). Each goal links to one or more
// portfolios for progress tracking; the linked portfolios' current
// value is summed and divided by `targetAmount` to get a completion
// percentage. SIP attribution (which monthly SIPs contribute to which
// goal) lives in `Goal.sipPlanIds` as a string[] FK array.

enum GoalCategory {
  RETIREMENT
  CHILD_EDUCATION
  HOME_PURCHASE
  EMERGENCY_FUND
  FIRE_CORPUS
  VEHICLE_PURCHASE
  TRAVEL
  WEALTH_BUILDING
  CUSTOM
}

enum GoalPriority {
  HIGH
  MEDIUM
  LOW
}

enum GoalStatus {
  ACTIVE
  ACHIEVED
  PAUSED
  ABANDONED
}

model Goal {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  category        GoalCategory  @default(CUSTOM)
  priority        GoalPriority  @default(MEDIUM)
  status          GoalStatus    @default(ACTIVE)

  /// Target corpus required at `targetDate`, in INR.
  targetAmount    Decimal       @db.Decimal(18, 2)
  /// Money the user already has earmarked for this goal — manual seed
  /// when the goal is created (e.g. opening balance from an old FD).
  initialAmount   Decimal       @db.Decimal(18, 2) @default(0)
  /// Assumed annual inflation rate (e.g. 0.06 for 6%). Used to render
  /// "inflation-adjusted target" hints in the UI.
  inflationRate   Decimal?      @db.Decimal(5, 4)
  /// Assumed annual return on the corpus. Used by the required-CAGR
  /// gauge — `(target / current) ^ (1/years) - 1` is the *required*
  /// return; this column lets the UI flag if expected < required.
  expectedReturn  Decimal?      @db.Decimal(5, 4)

  /// When the corpus must be ready by (e.g. age 60 for retirement,
  /// child's 18th birthday for education). Always >= today.
  targetDate      DateTime      @db.Date
  startDate       DateTime      @db.Date @default(now())

  /// Portfolios contributing to this goal. Sum of their current value
  /// → goal progress. Stored as an array because users frequently map
  /// the same goal to multiple portfolios (one parent, two SIP folios).
  portfolioIds    String[]      @default([])
  /// Optional notes (free-text, ≤4000 chars). Stored on the row to
  /// keep goal-detail reads cheap.
  notes           String?       @db.Text

  achievedAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([userId, status])
  @@index([userId, targetDate])
}

// ─── ACCOUNT AGGREGATOR CONSENTS ──────────────────────────────────
//
// One row per consent issued through an Account Aggregator (currently
// Finfactor / Finvu). The redirect URL points the user at the Finvu
// flow; once they approve, Finfactor pushes a /webhook/consent event,
// and the FIU passes back the `ecres` param on the callback URL.
// State machine:
//   INITIATED   – submit-consent-request-plus called, awaiting Finvu
//   PENDING     – user has the redirect open
//   APPROVED    – consent live; can call insights / statement
//   REJECTED    – user rejected
//   EXPIRED     – consent expired (Finvu sends webhook)
//   REVOKED     – we called submit-consent-revoke-request

model AaConsent {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider      String   @default("finfactor")
  consentHandle String?
  consentId     String?
  status        String   @default("INITIATED")
  fiTypes       String[]
  fipIds        String[]
  purposeCode   String?
  purposeText   String?
  redirectUrl   String?
  ecres         String?
  initiatedAt   DateTime  @default(now())
  approvedAt    DateTime?
  expiresAt     DateTime?
  revokedAt     DateTime?
  lastSyncedAt  DateTime?
  metadata      Json?

  @@unique([userId, consentHandle])
  @@index([userId, status])
  @@index([provider, status])
}
