  creditAccount   Account      @relation("CreditAccount", fields: [creditAccountId], references: [id])
  amount          Decimal      @db.Decimal(18, 4)
  narration       String?
  transactionId   String?
  transaction     Transaction? @relation(fields: [transactionId], references: [id])

  @@index([voucherId])
  @@index([debitAccountId])
  @@index([creditAccountId])
}

// ─── IMPORT JOBS ──────────────────────────────────────────────────

model ImportJob {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  portfolioId    String?
  type           ImportType
  status         ImportStatus @default(PENDING)
  fileName       String
  filePath       String
  broker         String?
  totalRows      Int?
  successRows    Int?
  failedRows     Int?
  errorLog       Json?
  // Phase C: content-hash dedup. SHA-256 of file bytes — replaces the
  // filename-only check that silently dropped same-named PDFs from
  // different emails (e.g. `Contract Note.pdf` daily).
  contentHash    String?
  // Source-of-fetch lineage. For Gmail-pulled attachments, the message id
  // these bytes came from. Lets us link Reports / DLQ entries back to the
  // original email and skip re-processing if poller revisits the message.
  gmailMessageId String?
  // Phase Gmail-FullInbox — back-reference when this job was promoted
  // from a discovered Gmail attachment. Null for direct uploads.
  gmailDocId     String?
  createdAt      DateTime     @default(now())
  completedAt    DateTime?

  transactions        Transaction[]
  gmailDiscoveredDocs GmailDiscoveredDoc[]

  @@index([userId, createdAt])
  @@index([userId, contentHash])
  @@index([userId, gmailMessageId])
}

enum ImportType {
  CONTRACT_NOTE_PDF
  CONTRACT_NOTE_EXCEL
  CONTRACT_NOTE_HTML
  MF_CAS_PDF
  MF_CAS_EXCEL
  BACK_OFFICE_CSV
  BANK_STATEMENT_PDF
  BANK_STATEMENT_CSV
  NPS_STATEMENT
  GENERIC_CSV
  GENERIC_EXCEL
}

enum ImportStatus {
  PENDING
  PROCESSING
  COMPLETED
  COMPLETED_WITH_ERRORS
  FAILED
  NEEDS_PASSWORD
}

// ─── GMAIL FULL-INBOX INGESTION ──────────────────────────────────

model GmailScanJob {
