  type            VoucherType
  voucherNo       String
  date            DateTime    @db.Date
  narration       String?
  isAutoGenerated Boolean     @default(false)
  createdAt       DateTime    @default(now())

  entries VoucherEntry[]

  @@unique([userId, type, voucherNo])
  @@index([userId, date])
}

enum VoucherType {
  JOURNAL
  PAYMENT
  RECEIPT
  CONTRA
  PURCHASE
  SALES
}

model VoucherEntry {
  id              String       @id @default(cuid())
