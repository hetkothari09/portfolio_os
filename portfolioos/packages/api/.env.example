# ─── Database ─────────────────────────────────────────────
# Runtime role: NOSUPERUSER + NOBYPASSRLS so §3.6 RLS policies are enforced.
# Migration 20260421150000_phase_4_5_rls_app_role creates the role with the
# dev password below. Override in production via ALTER ROLE + secret store.
DATABASE_URL=postgresql://portfolioos_app:portfolioos_app_dev@localhost:5432/portfolioos
# Migration / shadow-DB role: keeps superuser privileges for CREATE TABLE etc.
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/portfolioos

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-secure-random-string-at-least-32-chars
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ─── Email (for alerts / password reset) ─────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
SMTP_FROM="PortfolioOS <no-reply@portfolioos.in>"

# ─── Price data ───────────────────────────────────────────
NSE_API_KEY=
AMFI_NAV_URL=https://www.amfiindia.com/spages/NAVAll.txt

# ─── Storage ──────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# ─── App ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# ─── Web (Vite) ───────────────────────────────────────────
VITE_API_URL=http://localhost:3001
# Google Sign-In client ID (same OAuth client as the server below). The
# web app needs this to render the Google button; without it the button
# shows a stub "Google sign-in unavailable" message.
VITE_GOOGLE_CLIENT_ID=

# ─── Google OAuth (identity sign-in) ─────────────────────
# Create an OAuth 2.0 Client ID at https://console.cloud.google.com/apis/credentials
# Type: Web application. Add http://localhost:3000 to Authorized JavaScript
# origins. The same client ID goes into VITE_GOOGLE_CLIENT_ID above so the
# frontend's GSI button and the server's idToken verifier agree on audience.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=

# ─── OnlyOffice DocumentServer (in-browser doc editing) ──────
# JWT_SECRET must match the value set on the documentserver container.
# Generate a strong random one for prod:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ONLYOFFICE_JWT_SECRET=dev-onlyoffice-secret-change-me
ONLYOFFICE_JWT_ENABLED=true
ONLYOFFICE_PUBLIC_URL=http://localhost:8083
ONLYOFFICE_INTERNAL_URL=http://localhost:8083
# How OnlyOffice (in Docker) reaches the API (running on host).
# In Docker Desktop on Win/Mac, host.docker.internal resolves to the host.
API_PUBLIC_URL_FOR_ONLYOFFICE=http://host.docker.internal:3001

# ─── Finfactor (Account Aggregator — Wealthscape) ─────────────────
# UAT sandbox: https://dhanaprayoga.fiu.finfactor.in
# Prod: provided by Finfactor onboarding email — set per deployment.
# FINFACTOR_API_TOKEN is the long-lived FIU channel token issued by
# Finfactor; it is sent verbatim as `Authorization: Bearer <token>` on
# every API call. Keep out of source control.
# FINFACTOR_DEMO_MODE=true short-circuits every call to documented
# sample payloads so the Mutual Funds sandbox panel can render real-
# looking data without a live channel token. Use during onboarding
# only; never enable in prod.
FINFACTOR_BASE_URL=https://dhanaprayoga.fiu.finfactor.in
FINFACTOR_API_TOKEN=
FINFACTOR_DEMO_MODE=false
# Shared HMAC secret with Finfactor — webhooks are signed with this and
# verified via the X-Finfactor-Signature header. Required in prod; leave
# blank for local dev to accept any signature.
FINFACTOR_WEBHOOK_SECRET=
